{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "public",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/animations/:file*",
      "destination": "/animations/:file*"
    },
    {
      "source": "/((?!animations).*)",
      "destination": "/index.html"
    }
  ]
}
